# --- required ---
# Bearer token devices send. Any random 32+ char string.
# Generate one with: openssl rand -hex 32
RELAY_API_KEY=

# HTTP listen address. :8080 is the default; most platforms
# map 8080 to the public HTTPS port (e.g. Fly.io, Render).
RELAY_HTTP_ADDR=:8080

# Path to the BoltDB file. In Docker, this should be a mounted
# volume (/data/relay.db) so the DB persists across restarts.
RELAY_DB_PATH=/data/relay.db

# --- Apple Push Notification service (iOS) ---
# Get these from https://developer.apple.com/account/resources/authkeys/list
APNS_KEY_ID=
APNS_TEAM_ID=
# Path inside the container. Mount a secret volume here.
APNS_KEY_PATH=/secrets/apns/AuthKey_XXXXXX.p8
# Your iOS bundle identifier, exactly as registered in App Store Connect.
APNS_BUNDLE_ID=de.quavon.uptimepocket
# "sandbox" for TestFlight / debug builds, "production" for App Store.
APNS_ENVIRONMENT=production

# --- Firebase Cloud Messaging (Android) ---
# Get this from Firebase Console -> Project Settings -> Service Accounts
FCM_SERVICE_ACCOUNT_PATH=/secrets/fcm/service-account.json
FCM_PROJECT_ID=your-firebase-project-id

# --- behavior ---
# Coalesce rule: if 3+ transitions happen on the same server
# within 30s, send a single "critical" push instead of N.
RELAY_COALESCE_WINDOW=30s
RELAY_COALESCE_MIN=3

# --- logging ---
# One of: debug, info, warn, error
RELAY_LOG_LEVEL=info

# --- Sentry (optional crash reporting for the relay) ---
# Get a DSN from sentry.io (or your self-hosted Sentry). The relay
# NEVER phones home unless this is explicitly set. See docs/sentry.md
# for the privacy model + a list of what's scrubbed.
#
#   SENTRY_DSN=https://...@sentry.io/12345
#
# Tag events with an environment + release so you can filter
# issues by version. Defaults to "production" if unset.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
# Fraction of events to send (0.0..1.0). 0.1 captures 10% which
# is plenty for a self-hosted relay. 0.0 would drop everything,
# 1.0 sends everything. 0 is treated as "send all" by Sentry's
# SDK; use a small fraction like 0.05 if you want to truly
# downsample.
SENTRY_SAMPLE_RATE=0.1
